<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.easefun.polyv.livecommon.ui.widget.blurview.PLVBlurView
        android:id="@+id/blur_ly"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        app:plv_blurOverlayColor="#BF1B202D" />

    <com.easefun.polyv.livecommon.ui.widget.roundview.PLVRoundRectLayout
        android:id="@+id/plv_setting_virtual_bg_rl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#2c2c2c"
        android:clickable="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:plv_mode="all"
        app:plv_radius="10dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/plv_setting_virtual_bg_tv"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/plv_setting_virtual_bg_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="32dp"
                        android:layout_marginTop="32dp"
                        android:layout_marginBottom="16dp"
                        android:text="@string/plv_streamer_virtual_background"
                        android:textColor="#F0F1F5"
                        android:textSize="18sp" />

                    <!-- Professional Green Screen Toggle -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignTop="@+id/plv_setting_virtual_bg_tv"
                        android:layout_alignBottom="@+id/plv_setting_virtual_bg_tv"
                        android:layout_alignParentRight="true"
                        android:layout_marginRight="32dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:translationX="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/plv_streamer_professional_green_screen"
                            android:textColor="#F0F1F5"
                            android:textSize="16sp" />

                        <Switch
                            android:id="@+id/plv_professional_green_screen_toggle"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="6dp"
                            android:switchMinWidth="56dp" />
                    </LinearLayout>
                </RelativeLayout>

                <View
                    android:id="@+id/plv_setting_title_separator"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginLeft="32dp"
                    android:layout_marginRight="32dp"
                    android:background="#1AF0F1F5"
                    android:translationY="-6dp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- Professional Green Screen Settings (Initially Hidden) -->
                <LinearLayout
                    android:id="@+id/plv_professional_green_screen_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#252528"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="vertical"
                    android:paddingLeft="32dp"
                    android:paddingRight="32dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center|left"
                            android:text="@string/plv_streamer_curtain_color"
                            android:textColor="#F0F1F5"
                            android:textSize="14sp" />

                        <!-- Green Color Option -->
                        <ImageView
                            android:id="@+id/plv_curtain_color_green"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/plv_curtain_color_selector"
                            android:tag="green" />

                        <!-- Blue Color Option -->
                        <ImageView
                            android:id="@+id/plv_curtain_color_blue"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/plv_curtain_color_blue_selector"
                            android:tag="blue" />

                        <!-- Color Picker Button -->
                        <com.easefun.polyv.livecommon.ui.widget.roundview.PLVRoundRectLayout
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@null"
                            app:plv_radius="8dp">

                            <com.easefun.polyv.livecommon.ui.widget.roundview.PLVRoundImageView
                                android:id="@+id/plv_curtain_color_picker"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:layout_centerInParent="true"
                                android:background="#394150"
                                android:scaleType="centerInside"
                                android:src="@drawable/plv_ic_color_picker"
                                app:plv_radius_iv="8dp" />
                        </com.easefun.polyv.livecommon.ui.widget.roundview.PLVRoundRectLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_below="@+id/plv_setting_virtual_bg_tv"
                        android:background="#1AF0F1F5"
                        android:visibility="visible"
                        tools:visibility="visible" />

                    <!-- Advanced Adjustment Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="vertical">

                        <!-- Advanced Adjustment Header -->
                        <LinearLayout
                            android:id="@+id/plv_advanced_adjustment_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clipChildren="false"
                            android:clipToPadding="false"
                            android:gravity="center_vertical"
                            android:minHeight="52dp"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="10dp"
                                android:layout_weight="1"
                                android:clickable="false"
                                android:text="@string/plv_streamer_advanced_regulation"
                                android:textColor="#F0F1F5"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/plv_restore_recommended_btn"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="16dp"
                                android:background="@drawable/plv_streamer_restore_recommendations_bg"
                                android:padding="6dp"
                                android:text="@string/plv_streamer_restore_recommendations"
                                android:textColor="#70A3F3"
                                android:textSize="12sp"
                                android:visibility="gone"
                                tools:visibility="visible" />

                            <TextView
                                android:id="@+id/plv_advanced_adjustment_arrow"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:rotation="90"
                                android:scaleY="1.5"
                                android:text=">"
                                android:textColor="#6C727F"
                                android:textSize="18sp"
                                android:translationX="-6dp" />
                        </LinearLayout>

                        <!-- Advanced Adjustment Sliders (Initially Hidden) -->
                        <LinearLayout
                            android:id="@+id/plv_advanced_adjustment_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="12dp"
                            android:orientation="vertical"
                            android:visibility="gone"
                            tools:visibility="visible">

                            <!-- Keying Range Slider -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginBottom="16dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical"
                                    android:singleLine="true"
                                    android:text="@string/plv_streamer_chroma_keying_range"
                                    android:textColor="#D2D5DA"
                                    android:textSize="12sp" />

                                <SeekBar
                                    android:id="@+id/plv_keying_range_slider"
                                    android:layout_width="226dp"
                                    android:layout_height="26dp"
                                    android:max="100"
                                    android:maxHeight="6dp"
                                    android:progress="50"
                                    android:progressDrawable="@drawable/plv_slider_progress"
                                    android:thumb="@drawable/plv_slider_thumb" />
                            </LinearLayout>

                            <!-- Edge Softness Slider -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginBottom="16dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical"
                                    android:singleLine="true"
                                    android:text="@string/plv_streamer_edge_softening"
                                    android:textColor="#D2D5DA"
                                    android:textSize="12sp" />

                                <SeekBar
                                    android:id="@+id/plv_edge_softness_slider"
                                    android:layout_width="226dp"
                                    android:layout_height="26dp"
                                    android:max="100"
                                    android:maxHeight="6dp"
                                    android:progress="30"
                                    android:progressDrawable="@drawable/plv_slider_progress"
                                    android:thumb="@drawable/plv_slider_thumb" />
                            </LinearLayout>

                            <!-- Remove Ambient Light Slider -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginBottom="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical"
                                    android:singleLine="true"
                                    android:text="@string/plv_streamer_remove_ambient_light"
                                    android:textColor="#D2D5DA"
                                    android:textSize="12sp" />

                                <SeekBar
                                    android:id="@+id/plv_remove_ambient_light_slider"
                                    android:layout_width="226dp"
                                    android:layout_height="26dp"
                                    android:max="100"
                                    android:maxHeight="6dp"
                                    android:progress="20"
                                    android:progressDrawable="@drawable/plv_slider_progress"
                                    android:thumb="@drawable/plv_slider_thumb" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/plv_setting_virtual_bg_top_rv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#2c2c2c"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:paddingLeft="32dp"
                    android:paddingTop="16dp"
                    android:paddingRight="32dp"
                    android:scrollbars="none"
                    tools:itemCount="2" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/plv_setting_virtual_bg_bottom_rv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#2c2c2c"
                    android:overScrollMode="never"
                    android:paddingLeft="32dp"
                    android:paddingRight="32dp"
                    android:scrollbars="none"
                    tools:itemCount="2" />

            </LinearLayout>
        </ScrollView>
    </com.easefun.polyv.livecommon.ui.widget.roundview.PLVRoundRectLayout>
</FrameLayout>